# Database Configuration
DATABASE_URL=mysql://user:password@host:3306/chileforyou_ai

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Manus OAuth Configuration
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# Owner Information
OWNER_EMAIL=info@chileforyou.ai
OWNER_NAME=Chile For You
OWNER_OPEN_ID=your-owner-open-id

# Business Configuration
COMMISSION_PERCENTAGE=20

# OpenAI API (for AI Avatar)
OPENAI_API_KEY=sk-your-openai-api-key

# Manus Built-in APIs
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# Application Configuration
VITE_APP_TITLE=Chile For You - Agencia de Viajes Virtual
VITE_APP_LOGO=https://your-cdn-url/logo.png

# Node Environment
NODE_ENV=production

# Port (Railway will set this automatically, but you can override)
PORT=3000
